NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SITE_URL=https://lekkerplekje.com

# Optional. If unset, Sentry no-ops.
NEXT_PUBLIC_SENTRY_DSN=
# Optional. Only needed for readable stack traces (source maps).
# Generate at https://lekkerplekje.sentry.io/settings/auth-tokens/
SENTRY_AUTH_TOKEN=

# Push notifications (VAPID). Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@lekkerplekje.com

# Shared secret for Vercel Cron-triggered routes (dispatcher + producers).
CRON_SECRET=
